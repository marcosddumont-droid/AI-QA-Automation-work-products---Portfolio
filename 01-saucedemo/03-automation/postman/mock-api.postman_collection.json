{
  "info": {
    "name": "QA Portfolio · Mock API",
    "description": "Colección de API contra el mock local del portfolio.\n\nSauceDemo no expone una API pública, así que la cobertura de API de esta aplicación se hace contra el mock incluido en tools/mock-api. Las colecciones contra APIs reales están en 02-practice-software-testing.\n\nLevantar el mock antes de correr:\n  node tools/mock-api/server.js",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "API-01 · Health check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('API-01 responde 200', () => pm.response.to.have.status(200));",
              "pm.test('API-01 el estado es ok', () => {",
              "  pm.expect(pm.response.json().status).to.eql('ok');",
              "});",
              "pm.test('API-01 responde en menos de 500 ms', () => {",
              "  pm.expect(pm.response.responseTime).to.be.below(500);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/api/health", "host": ["{{baseUrl}}"], "path": ["api", "health"] }
      }
    },
    {
      "name": "API-02 · Login exitoso",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('API-02 responde 200', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "pm.test('API-02 devuelve un token', () => {",
              "  pm.expect(body.token).to.be.a('string').and.to.match(/^tok_/);",
              "});",
              "",
              "// Se guarda para las requests siguientes: encadenamiento de la colección.",
              "pm.collectionVariables.set('token', body.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usuario\": \"demo\",\n  \"password\": \"demo123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/login", "host": ["{{baseUrl}}"], "path": ["api", "login"] }
      }
    },
    {
      "name": "API-03 · Login con credenciales inválidas",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('API-03 rechaza con 401', () => pm.response.to.have.status(401));",
              "pm.test('API-03 informa el motivo', () => {",
              "  pm.expect(pm.response.json().error).to.eql('Credenciales inválidas');",
              "});",
              "pm.test('API-03 no filtra un token', () => {",
              "  pm.expect(pm.response.json().token).to.be.undefined;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usuario\": \"demo\",\n  \"password\": \"clave_incorrecta\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/login", "host": ["{{baseUrl}}"], "path": ["api", "login"] }
      }
    },
    {
      "name": "API-04 · Listar productos",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('API-04 responde 200', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "pm.test('API-04 respeta el parámetro limit', () => {",
              "  pm.expect(body.items).to.have.lengthOf(5);",
              "});",
              "pm.test('API-04 informa el total real, no el limitado', () => {",
              "  pm.expect(body.total).to.eql(20);",
              "});",
              "pm.test('API-04 cada producto tiene el contrato esperado', () => {",
              "  body.items.forEach((p) => {",
              "    pm.expect(p).to.have.all.keys('id', 'nombre', 'precio', 'stock');",
              "    pm.expect(p.precio).to.be.a('number').and.to.be.above(0);",
              "    pm.expect(p.stock).to.be.at.least(0);",
              "  });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/products?limit=5",
          "host": ["{{baseUrl}}"],
          "path": ["api", "products"],
          "query": [{ "key": "limit", "value": "5" }]
        }
      }
    },
    {
      "name": "API-05 · Crear orden",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('API-05 responde 201', () => pm.response.to.have.status(201));",
              "",
              "const body = pm.response.json();",
              "pm.test('API-05 devuelve un id de orden', () => {",
              "  pm.expect(body.ordenId).to.be.a('number').and.to.be.above(0);",
              "});",
              "pm.test('API-05 la orden queda confirmada', () => {",
              "  pm.expect(body.estado).to.eql('confirmada');",
              "});",
              "pm.test('API-05 refleja los datos enviados', () => {",
              "  pm.expect(body.productoId).to.eql(3);",
              "  pm.expect(body.cantidad).to.eql(2);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"productoId\": 3,\n  \"cantidad\": 2\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
      }
    },
    {
      "name": "API-06 · Crear orden sin campos obligatorios",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('API-06 rechaza con 422', () => pm.response.to.have.status(422));",
              "pm.test('API-06 indica qué campos faltan', () => {",
              "  pm.expect(pm.response.json().error).to.include('productoId');",
              "  pm.expect(pm.response.json().error).to.include('cantidad');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"cantidad\": 1\n}" },
        "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }
      }
    },
    {
      "name": "API-07 · Endpoint inexistente",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('API-07 responde 404', () => pm.response.to.have.status(404));",
              "pm.test('API-07 el cuerpo del error es JSON', () => {",
              "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "  pm.expect(pm.response.json().error).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/no-existe",
          "host": ["{{baseUrl}}"],
          "path": ["api", "no-existe"]
        }
      }
    }
  ]
}
